{
  "name": "dev-toolbox",
  "private": true,
  "version": "0.1.0",
  "description": "A desktop developer toolkit — crypto, encoding, formatting, conversion, and inspection tools built on Tauri v2 + Vue 3 + Rust",
  "author": "smallLazy",
  "license": "MIT",
  "homepage": "https://github.com/smallLazy/dev-toolbox",
  "repository": {
    "type": "git",
    "url": "https://github.com/smallLazy/dev-toolbox.git"
  },
  "keywords": [
    "developer-tools",
    "desktop-app",
    "tauri",
    "vue",
    "rust",
    "crypto",
    "encoding",
    "toolbox"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "create-plugin": "npx tsx scripts/create-plugin.ts",
    "test": "npx vitest run --passWithNoTests",
    "validate": "npx vue-tsc --noEmit && npm test && npx tsx scripts/ci/validate-architecture.ts && npx tsx scripts/ci/validate-design.ts && npx tsx scripts/ci/validate-plugins.ts && npx tsx scripts/ci/validate-ai.ts",
    "validate:arch": "npx tsx scripts/ci/validate-architecture.ts",
    "validate:design": "npx tsx scripts/ci/validate-design.ts",
    "validate:plugins": "npx tsx scripts/ci/validate-plugins.ts",
    "validate:ai": "npx tsx scripts/ci/validate-ai.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-store": "^2.2.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^2.2.0"
  }
}
